// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  //url      = env("DATABASE_URL")
}


enum ApprovalDecisionType {
  APPROVED
  REJECTED
}

enum OrderApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum ApprovalStepStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

// =========================================================
// CORE ENTITIES
// =========================================================

model Address {
  id           String    @id @default(uuid(7)) @db.Uuid
  name         String    @db.VarChar(100)
  street       String    @db.VarChar(150)
  neighborhood String    @db.VarChar(100)
  number       String    @db.VarChar(20)
  postalCode   String    @db.VarChar(20)
  complement   String?   @db.VarChar(100)

  // Relations
  users             User[]
  contacts          ContactAddress[]
  
  // CRM/ERP IMPROVEMENT: Link Address directly to Orders. 
  // Systems like SAP and Salesforce distinguish tightly between "Ship-To" and "Bill-To" linked directly to address snapshots.
  ordersShipping    Order[]   @relation("OrderShippingAddress")
  ordersPayment     Order[]   @relation("OrderPaymentAddress")
  
  branch            Branch?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("Address")
}

model User {
  id                     String     @id @default(uuid(7)) @db.Uuid
  name                   String     @db.VarChar(100)
  surname                String     @db.VarChar(100)
  username               String     @unique @db.VarChar(100)
  email                  String     @unique @db.VarChar(150)
  alternativeEmail       String?    @db.VarChar(150)
  bornDate               DateTime   @db.Date
  govId                  String     @unique @db.Char(14)
  password               String     @db.Text
  phoneNumber            String?    @db.VarChar(30)
  
  // Account Recovery
  passwordResetToken     String?    @unique
  passwordResetExpires   DateTime?

  addressId              String     @db.Uuid
  address                Address    @relation(fields: [addressId], references: [id])

  // Relations
  ownedAccounts          Account[]  @relation("AccountOwner")
  profiles               UserProfile[]
  approvalRequestedOrders Order[]    @relation("OrderApprovalRequester")
  approvalDecisions       ApprovalDecision[]

  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  @@map("User")
}

model Profile {
  id          String   @id @default(uuid(7)) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.Text

  users       UserProfile[]
  approvalStepProfiles ApprovalStepProfile[]
  approvalDecisions    ApprovalDecision[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("Profile")
}

model UserProfile {
  userId     String    @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId  String    @db.Uuid
  profile    Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  isActive   Boolean   @default(true)
  assignedAt DateTime  @default(now())
  revokedAt  DateTime?

  @@id([userId, profileId])
  @@index([profileId])
  @@map("UserProfile")
}


model Account {
  id            String    @id @default(uuid(7)) @db.Uuid
  govId         String    @unique @db.VarChar(18)
  officialName  String    @db.VarChar(150)
  fantasyName   String?   @db.VarChar(150)
  phoneNumber   String?   @db.VarChar(30)
  email         String?   @db.VarChar(150)

  // Hierarchy
  mainAccountId String?   @db.Uuid
  mainAccount   Account?  @relation("AccountHierarchy", fields: [mainAccountId], references: [id])
  subAccounts   Account[] @relation("AccountHierarchy")

  ownerUserId   String    @db.Uuid
  owner         User      @relation("AccountOwner", fields: [ownerUserId], references: [id])

  // Relations
  contacts      Contact[]
  quotes        Quote[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("Account")
}

model Contact {
  id           String    @id @default(uuid(7)) @db.Uuid
  officialName String    @db.VarChar(150)
  nickname     String?   @db.VarChar(100)
  
  accountId    String    @db.Uuid
  account      Account   @relation(fields: [accountId], references: [id])

  // Relations
  addresses    ContactAddress[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("Contact")
}

model ContactAddress {
  contactId String  @db.Uuid
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  addressId String  @db.Uuid
  address   Address @relation(fields: [addressId], references: [id], onDelete: Cascade)

  @@id([contactId, addressId])
  @@map("ContactAddress")
}

// =========================================================
// SALES & BILLING (ORDERS, QUOTES, ETC.)
// =========================================================

model Status {
  id        String   @id @default(uuid(7)) @db.Uuid
  name      String   @unique @db.VarChar(50)
  
  // Relations
  orders    Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Status")
}

model Quote {
  id          String   @id @default(uuid(7)) @db.Uuid
  name        String   @db.VarChar(150)
  destination String?  @db.VarChar(150)
  finalValue  Decimal  @db.Decimal(12, 2)
  
  accountId   String   @db.Uuid
  account     Account  @relation(fields: [accountId], references: [id])

  // Relations
  orders      Order[]
  products    QuoteProduct[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("Quote")
}

model QuoteProduct {
  quoteId     String  @db.Uuid
  quote       Quote   @relation(fields: [quoteId], references: [id])
  productId   String  @db.Uuid
  product     Product @relation(fields: [productId], references: [id])
  quantity    Decimal @db.Decimal(10, 2)
  price       Decimal @db.Decimal(12, 2)
  discount    Decimal @db.Decimal(12, 2)
  finalPrice  Decimal @db.Decimal(12, 2)

  @@id([quoteId, productId])
  @@map("QuoteProduct")
}

model Order {
  id                String   @id @default(uuid(7)) @db.Uuid
  name              String   @db.VarChar(150)
  origin            String?  @db.VarChar(150)
  destination       String?  @db.VarChar(150)
  finalValue        Decimal  @db.Decimal(12, 2)

  quoteId           String?  @db.Uuid
  quote             Quote?   @relation(fields: [quoteId], references: [id])

  statusId          String   @db.Uuid
  status            Status   @relation(fields: [statusId], references: [id])

  priceCatalogId    String   @db.Uuid
  priceCatalog      PriceCatalog @relation(fields: [priceCatalogId], references: [id])

  // Missing in SQL, inferred from description
  paymentConditionId String? @db.Uuid
  paymentCondition   PaymentCondition? @relation(fields: [paymentConditionId], references: [id])

  // CRM/ERP IMPROVEMENT: Strongly link Ship & Bill addresses to the Address table. 
  // Future tip: In rigorous ERPs (like SAP), addresses in Orders are cloned/snapshotted 
  // (or linked to an immutable historical address) so past invoices don't change if the client moves.
  shippingAddressId  String?  @db.Uuid
  shippingAddress    Address? @relation("OrderShippingAddress", fields: [shippingAddressId], references: [id])
  
  paymentAddressId   String?  @db.Uuid
  paymentAddress     Address? @relation("OrderPaymentAddress", fields: [paymentAddressId], references: [id])

  // Approval context: policy defines the profile-based flow; the fields below
  // keep the current order approval state and business observation visible on the order.
  approvalPolicyId          String?             @db.Uuid
  approvalPolicy            ApprovalPolicy?     @relation(fields: [approvalPolicyId], references: [id])
  approvalRequestedByUserId String?             @db.Uuid
  approvalRequestedBy       User?               @relation("OrderApprovalRequester", fields: [approvalRequestedByUserId], references: [id])
  approvalStatus            OrderApprovalStatus @default(NOT_REQUIRED)
  approvalSubmittedAt       DateTime?
  approvalResolvedAt        DateTime?
  approvalObservation       String?             @db.Text
  approvals                 OrderApproval[]

  // CRM/ERP IMPROVEMENT: Stock movements should trace back to the order that triggered them.
  // storageMovements   StorageMovement[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([approvalStatus])
  @@index([approvalPolicyId])
  @@map("Order")
}

model ApprovalPolicy {
  id            String    @id @default(uuid(7)) @db.Uuid
  name          String    @unique @db.VarChar(100)
  description   String?   @db.Text
  isActive      Boolean   @default(true)
  minOrderValue Decimal?  @db.Decimal(12, 2)
  maxOrderValue Decimal?  @db.Decimal(12, 2)
  currency      String?   @db.Char(3)

  orders        Order[]
  steps         ApprovalStep[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isActive, currency])
  @@map("ApprovalPolicy")
}

model ApprovalStep {
  id                String    @id @default(uuid(7)) @db.Uuid
  policyId          String    @db.Uuid
  policy            ApprovalPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  sequence          Int
  name              String    @db.VarChar(100)
  description       String?   @db.Text
  requiredApprovals Int       @default(1)
  isFinalStep       Boolean   @default(false)

  profiles          ApprovalStepProfile[]
  orderApprovals    OrderApproval[]

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([policyId, sequence])
  @@map("ApprovalStep")
}

model ApprovalStepProfile {
  approvalStepId String       @db.Uuid
  approvalStep   ApprovalStep @relation(fields: [approvalStepId], references: [id], onDelete: Cascade)
  profileId      String       @db.Uuid
  profile        Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@id([approvalStepId, profileId])
  @@index([profileId])
  @@map("ApprovalStepProfile")
}

model OrderApproval {
  id             String              @id @default(uuid(7)) @db.Uuid
  orderId        String              @db.Uuid
  order          Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  approvalStepId String              @db.Uuid
  approvalStep   ApprovalStep        @relation(fields: [approvalStepId], references: [id])
  status         ApprovalStepStatus  @default(PENDING)
  requestedAt    DateTime            @default(now())
  resolvedAt     DateTime?
  observation    String?             @db.Text

  decisions      ApprovalDecision[]

  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([orderId, approvalStepId])
  @@index([status])
  @@map("OrderApproval")
}

model ApprovalDecision {
  id              String               @id @default(uuid(7)) @db.Uuid
  orderApprovalId String               @db.Uuid
  orderApproval   OrderApproval        @relation(fields: [orderApprovalId], references: [id], onDelete: Cascade)
  userId          String               @db.Uuid
  user            User                 @relation(fields: [userId], references: [id])
  // The selected profile must be one of the user's active UserProfile records
  // and one of the profiles allowed for the approval step.
  profileId       String               @db.Uuid
  profile         Profile              @relation(fields: [profileId], references: [id])
  isApproved      Boolean?             @default(false)
  observation     String?              @db.Text
  decidedAt       DateTime             @default(now())

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([orderApprovalId, userId])
  @@index([profileId])
  @@map("ApprovalDecision")
}

model PaymentCondition {
  id            String   @id @default(uuid(7)) @db.Uuid
  paymentType   String   @db.VarChar(50)
  installments  Int
  currency      String   @db.Char(3)
  finalAmount   Decimal  @db.Decimal(12, 2)
  interest      Decimal  @db.Decimal(12, 2) // Could be percentage or flat

  orders        Order[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("PaymentCondition")
}

// =========================================================
// PRODUCT & CATALOG
// =========================================================

model PriceCatalog {
  id        String   @id @default(uuid(7)) @db.Uuid
  name      String   @db.VarChar(100)
  currency  String   @db.Char(3)

  products  PriceCatalogProduct[]
  orders    Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("PriceCatalog")
}

model Product {
  id           String   @id @default(uuid(7)) @db.Uuid
  name         String   @db.VarChar(150)
  nickname     String?  @db.VarChar(100)
  provider     String?  @db.VarChar(150)
  basePrice    Decimal? @db.Decimal(12, 2)
  defaultCurrency String?  @db.Char(3)
  ncm          String?  @db.VarChar(50)
  productCode  String   @unique @db.VarChar(20)
  pictureUrl   String?  @db.Text // Suggestion for simple file reference

  // Relations
  catalogs     PriceCatalogProduct[]
  structure    Structure?
  components   StructureProduct[]
  storages     StorageProduct[]
  // movements    StorageMovement[]
  quotes       QuoteProduct[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("Product")
}

model PriceCatalogProduct {
  id             String       @id @default(uuid(7)) @db.Uuid
  priceCatalogId String       @db.Uuid
  priceCatalog   PriceCatalog @relation(fields: [priceCatalogId], references: [id])
  productId      String       @db.Uuid
  product        Product      @relation(fields: [productId], references: [id])
  basePrice      Decimal      @db.Decimal(12, 2)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([priceCatalogId, productId])
  @@map("PriceCatalogProduct")
}

// CRM/ERP IMPROVEMENT: Rename "Structure" context to "Bill of Material" (BOM).
// While the Prisma models are named Structure/StructureProduct as requested, mapping them 
// to BILL_OF_MATERIAL in the database aligns with the universal industry standard (BOM).
model Structure {
  id         String   @id @default(uuid(7)) @db.Uuid
  
  productId  String   @unique @db.Uuid
  product    Product  @relation(fields: [productId], references: [id])

  components StructureProduct[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("BillOfMaterial") // Formerly "STRUCTURE"
}

model StructureProduct {
  structureId        String    @db.Uuid
  structure          Structure @relation(fields: [structureId], references: [id], onDelete: Cascade)
  
  componentProductId String    @db.Uuid
  componentProduct   Product   @relation(fields: [componentProductId], references: [id])
  
  quantity           Decimal   @db.Decimal(10, 2)

  @@id([structureId, componentProductId])
  @@map("BomItem") // Formerly "STRUCTURE_PRODUCT"
}

// =========================================================
// LOGISTICS & INVENTORY
// =========================================================

model Branch {
  id           String    @id @default(uuid(7)) @db.Uuid
  govId        String    @unique @db.VarChar(18)
  officialName String    @db.VarChar(150)
  fantasyName  String?   @db.VarChar(150)
  phoneNumber  String?   @db.VarChar(30)
  email        String?   @db.VarChar(150)

  addressId    String    @unique @db.Uuid
  address      Address   @relation(fields: [addressId], references: [id])

  storages     Storage[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("Branch")
}

model Storage {
  id                 String   @id @default(uuid(7)) @db.Uuid
  name               String   @db.VarChar(100)
  storageCode        String   @unique @db.VarChar(50) // e.g. STRG0001
  
  branchId           String   @db.Uuid
  branch             Branch   @relation(fields: [branchId], references: [id])
  
  logisticsContactId String?  @db.Uuid
  //logisticsContact   Contact? @relation("LogisticsContact", fields: [logisticsContactId], references: [id])

  products           StorageProduct[]
  // movementsOut       StorageMovement[] @relation("FromStorage")
  // movementsIn        StorageMovement[] @relation("ToStorage")

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("Storage")
}

model StorageProduct {
  id                String   @id @default(uuid(7)) @db.Uuid
  storageId         String   @db.Uuid
  storage           Storage  @relation(fields: [storageId], references: [id])
  
  productId         String   @db.Uuid
  product           Product  @relation(fields: [productId], references: [id])
  
  availableQuantity Decimal  @db.Decimal(12, 2)
  committedQuantity Decimal  @db.Decimal(12, 2)
  totalQuantity     Decimal  @db.Decimal(12, 2)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([storageId, productId])
  @@map("StorageProduct")
}

